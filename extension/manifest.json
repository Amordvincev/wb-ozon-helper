{
  "manifest_version": 3,
  "name": "WB-Ozon Помощник",
  "version": "1.0.0",
  "description": "История цен, анализ продавца и остатков на Wildberries и Ozon",
  "permissions": [
    "storage",
    "alarms",
    "activeTab"
  ],
  "host_permissions": [
    "https://www.wildberries.ru/*",
    "https://www.ozon.ru/*",
    "https://wb-ozon-helper.onrender.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.wildberries.ru/catalog/*/detail.aspx*", "https://www.wildberries.ru/catalog/*"],
      "js": ["content/wb-content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.ozon.ru/product/*"],
      "js": ["content/ozon-content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
